v0x5dfe48f4e8e0_0 .var/i "i", 31 0;
v0x5dfe48f4e980_0 .net "nand_y", 0 0, L_0x5dfe48f4f2e0;  1 drivers
v0x5dfe48f4ea20_0 .net "nor_y", 0 0, L_0x5dfe48f4f350;  1 drivers
