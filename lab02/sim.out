    .scope S_0x5dfe48efc490;
T_0 ;
    %vpi_call 2 29 "$dumpfile", "lab02_logic_gates.vcd" {0 0 0};
    %vpi_call 2 30 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x5dfe48efc490 {0 0 0};
    %vpi_call 2 32 "$display", "a b | and or not_a xor nand nor xnor" {0 0 0};
    %vpi_call 2 33 "$display", "-------------------------------------" {0 0 0};
    %pushi/vec4 0, 0, 32;
    %store/vec4 v0x5dfe48f4e8e0_0, 0, 32;
T_0.0 ;
    %load/vec4 v0x5dfe48f4e8e0_0;
    %cmpi/s 4, 0, 32;
    %jmp/0xz T_0.1, 5;
    %load/vec4 v0x5dfe48f4e8e0_0;
    %parti/s 2, 0, 2;
    %split/vec4 1;
    %store/vec4 v0x5dfe48f4e840_0, 0, 1;
    %store/vec4 v0x5dfe48f4e6e0_0, 0, 1;
    %delay 10000, 0;
    %vpi_call 2 38 "$display", "%b %b |  %b   %b    %b    %b    %b    %b    %b", v0x5dfe48f4e6e0_0, v0x5dfe48f4e840_0, v0x5dfe48f4e7a0_0, v0x5dfe48f4eb90_0, v0x5dfe48f4eac0_0, v0x5dfe48f4edc0_0, v0x5dfe48f4e980_0, v0x5dfe48f4ea20_0, v0x5dfe48f4ec60_0 {0 0 0};
    %load/vec4 v0x5dfe48f4e8e0_0;
    %addi 1, 0, 32;
    %store/vec4 v0x5dfe48f4e8e0_0, 0, 32;
    %jmp T_0.0;
T_0.1 ;
    %vpi_call 2 42 "$finish" {0 0 0};
    %end;
    .thread T_0;
