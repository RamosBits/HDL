S_0x5dfe48efc620 .scope module, "uut" "logic_gates" 2 16, 3 3 0, S_0x5dfe48efc490;
 .timescale -9 -12;
    .port_info 0 /INPUT 1 "a";
    .port_info 1 /INPUT 1 "b";
    .port_info 2 /OUTPUT 1 "and_y";
    .port_info 3 /OUTPUT 1 "or_y";
    .port_info 4 /OUTPUT 1 "not_a_y";
    .port_info 5 /OUTPUT 1 "xor_y";
    .port_info 6 /OUTPUT 1 "nand_y";
    .port_info 7 /OUTPUT 1 "nor_y";
