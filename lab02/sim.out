L_0x5dfe48f4ee90 .functor AND 1, v0x5dfe48f4e6e0_0, v0x5dfe48f4e840_0, C4<1>, C4<1>;
L_0x5dfe48f4efa0 .functor OR 1, v0x5dfe48f4e6e0_0, v0x5dfe48f4e840_0, C4<0>, C4<0>;
L_0x5dfe48f4f060 .functor NOT 1, v0x5dfe48f4e6e0_0, C4<0>, C4<0>, C4<0>;
L_0x5dfe48f4f1b0 .functor XOR 1, v0x5dfe48f4e6e0_0, v0x5dfe48f4e840_0, C4<0>, C4<0>;
L_0x5dfe48f4f2e0 .functor NAND 1, v0x5dfe48f4e6e0_0, v0x5dfe48f4e840_0, C4<1>, C4<1>;
L_0x5dfe48f4f350 .functor NOR 1, v0x5dfe48f4e6e0_0, v0x5dfe48f4e840_0, C4<0>, C4<0>;
L_0x5dfe48f4f450 .functor XNOR 1, v0x5dfe48f4e6e0_0, v0x5dfe48f4e840_0, C4<0>, C4<0>;
v0x5dfe48f35a50_0 .net "a", 0 0, v0x5dfe48f4e6e0_0;  1 drivers
v0x5dfe48f4df90_0 .net "and_y", 0 0, L_0x5dfe48f4ee90;  alias, 1 drivers
v0x5dfe48f4e050_0 .net "b", 0 0, v0x5dfe48f4e840_0;  1 drivers
v0x5dfe48f4e0f0_0 .net "nand_y", 0 0, L_0x5dfe48f4f2e0;  alias, 1 drivers
v0x5dfe48f4e1b0_0 .net "nor_y", 0 0, L_0x5dfe48f4f350;  alias, 1 drivers
v0x5dfe48f4e2c0_0 .net "not_a_y", 0 0, L_0x5dfe48f4f060;  alias, 1 drivers
v0x5dfe48f4e380_0 .net "or_y", 0 0, L_0x5dfe48f4efa0;  alias, 1 drivers
v0x5dfe48f4e440_0 .net "xnor_y", 0 0, L_0x5dfe48f4f450;  alias, 1 drivers
