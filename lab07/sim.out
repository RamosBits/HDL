#! /usr/bin/vvp
:ivl_version "12.0 (stable)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision - 12;
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/system.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_sys.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_textio.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2005_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/va_math.vpi";
S_0x60b702f0cee0 .scope module, "tb_counter_divider" "tb_counter_divider" 2 3;
 .timescale -9 -12;
v0x60b702f21f20_0 .var "clk", 0 0;
v0x60b702f21fe0_0 .net "count", 3 0, v0x60b702f21c00_0;  1 drivers
v0x60b702f220b0_0 .var "reset", 0 0;
v0x60b702f221b0_0 .net "slow_clk", 0 0, v0x60b702f21db0_0;  1 drivers
S_0x60b702f0d070 .scope module, "uut" "counter_divider" 2 9, 3 3 0, S_0x60b702f0cee0;
 .timescale -9 -12;
    .port_info 0 /INPUT 1 "clk";
    .port_info 1 /INPUT 1 "reset";
    .port_info 2 /OUTPUT 4 "count";
    .port_info 3 /OUTPUT 1 "slow_clk";
P_0x60b702f0d200 .param/l "TERMINAL_COUNT" 0 3 4, C4<0111>;
v0x60b702efb2d0_0 .net "clk", 0 0, v0x60b702f21f20_0;  1 drivers
v0x60b702f21c00_0 .var "count", 3 0;
v0x60b702f21ce0_0 .net "reset", 0 0, v0x60b702f220b0_0;  1 drivers
v0x60b702f21db0_0 .var "slow_clk", 0 0;
E_0x60b702f0b200 .event posedge, v0x60b702efb2d0_0;
    .scope S_0x60b702f0d070;
T_0 ;
    %wait E_0x60b702f0b200;
    %load/vec4 v0x60b702f21ce0_0;
    %flag_set/vec4 8;
    %jmp/0xz  T_0.0, 8;
    %pushi/vec4 0, 0, 4;
    %assign/vec4 v0x60b702f21c00_0, 0;
    %pushi/vec4 0, 0, 1;
    %assign/vec4 v0x60b702f21db0_0, 0;
    %jmp T_0.1;
T_0.0 ;
    %load/vec4 v0x60b702f21c00_0;
    %cmpi/e 7, 0, 4;
    %jmp/0xz  T_0.2, 4;
    %pushi/vec4 0, 0, 4;
    %assign/vec4 v0x60b702f21c00_0, 0;
    %load/vec4 v0x60b702f21db0_0;
    %inv;
    %assign/vec4 v0x60b702f21db0_0, 0;
    %jmp T_0.3;
T_0.2 ;
    %load/vec4 v0x60b702f21c00_0;
    %addi 1, 0, 4;
    %assign/vec4 v0x60b702f21c00_0, 0;
T_0.3 ;
T_0.1 ;
    %jmp T_0;
    .thread T_0;
    .scope S_0x60b702f0cee0;
T_1 ;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x60b702f21f20_0, 0, 1;
T_1.0 ;
    %delay 5000, 0;
    %load/vec4 v0x60b702f21f20_0;
    %inv;
    %store/vec4 v0x60b702f21f20_0, 0, 1;
    %jmp T_1.0;
    %end;
    .thread T_1;
    .scope S_0x60b702f0cee0;
T_2 ;
    %vpi_call 2 17 "$dumpfile", "lab07_counter_divider.vcd" {0 0 0};
    %vpi_call 2 18 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x60b702f0cee0 {0 0 0};
    %vpi_call 2 20 "$display", "time reset count slow_clk" {0 0 0};
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x60b702f220b0_0, 0, 1;
    %delay 12000, 0;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x60b702f220b0_0, 0, 1;
    %delay 180000, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x60b702f220b0_0, 0, 1;
    %delay 10000, 0;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x60b702f220b0_0, 0, 1;
    %delay 100000, 0;
    %vpi_call 2 31 "$finish" {0 0 0};
    %end;
    .thread T_2;
    .scope S_0x60b702f0cee0;
T_3 ;
    %wait E_0x60b702f0b200;
    %delay 1000, 0;
    %vpi_call 2 36 "$display", "%4t   %b     %d      %b", $time, v0x60b702f220b0_0, v0x60b702f21fe0_0, v0x60b702f221b0_0 {0 0 0};
    %jmp T_3;
    .thread T_3;
